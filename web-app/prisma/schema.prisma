generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  users     User[]
}

model User {
  id             String   @id @default(cuid())
  username       String
  email          String   @unique
  password       String
  role           String   @default("user") // "admin", "user"
  emailVerified  Boolean  @default(false)
  createdAt      DateTime @default(now())
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantId       String
  verificationTokens EmailVerificationToken[]

  @@unique([username, tenantId])
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  token     String   @unique
  type      String   // "verification" | "invite"
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
}

model SystemConfig {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  description String?
  updatedAt   DateTime @updatedAt
}

model Dashboard {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  widgets   Widget[]
}

model Widget {
  id          String    @id @default(cuid())
  type        String    // "gauge", "toggle", "chart", "slider"
  label       String
  feedKey     String
  feedName    String
  settings    String    // JSON string for widget-specific settings
  x           Int
  y           Int
  w           Int
  h           Int
  order       Int       @default(0)
  dashboard   Dashboard @relation(fields: [dashboardId], references: [id], onDelete: Cascade)
  dashboardId String
}

model AioAccount {
  id          String       @id @default(cuid())
  name        String
  username    String       @unique
  key         String
  feeds       FeedConfig[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model FeedConfig {
  id          String      @id @default(cuid())
  key         String      @unique
  name        String
  lastValue   String?
  accountId   String?
  account     AioAccount? @relation(fields: [accountId], references: [id], onDelete: Cascade)
  updatedAt   DateTime    @updatedAt
}

model OpenDataSource {
  id            String   @id @default(cuid())
  name          String
  url           String
  jsonPath      String
  scheduleCron  String
  targetFeedKey String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Automation {
  id                String             @id @default(cuid())
  name              String
  type              String             @default("EVENT") // "EVENT" or "TIME"
  scheduleCron      String?            // e.g. "0 8 * * *"
  timezone          String?            // e.g. "Asia/Jakarta"
  conditionMatch    String             @default("ALL")
  elseConditionMatch String            @default("ALL")
  conditions        AutomationCondition[]
  actions           AutomationAction[]
  isActive          Boolean            @default(true)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
}

model AutomationCondition {
  id           String     @id @default(cuid())
  feedKey      String
  operator     String
  value        String
  isElse       Boolean    @default(false)
  automation   Automation @relation(fields: [automationId], references: [id], onDelete: Cascade)
  automationId String
}

model AutomationAction {
  id           String     @id @default(cuid())
  type         String     @default("publish") // "publish", "delay", or "webhook"
  feedKey      String?
  value        String?
  delayMs      Int?       @default(0)
  targetUrl    String?
  payload      String?
  order        Int        @default(0)
  isElse       Boolean    @default(false)
  automation   Automation @relation(fields: [automationId], references: [id], onDelete: Cascade)
  automationId String
}

model DataPoint {
  id        String   @id @default(cuid())
  feedKey   String
  value     String
  createdAt DateTime @default(now())

  @@index([feedKey, createdAt])
}
